# =========================================
# OneMCP v1 — Environment Configuration
# Copy to .env and edit before docker compose up
# =========================================

# --- Postgres ---
POSTGRES_DB=onemcp
POSTGRES_USER=onemcp
POSTGRES_PASSWORD=change-me-strong-password

# --- MinIO ---
MINIO_ROOT_USER=onemcp
MINIO_ROOT_PASSWORD=change-me-min-8-chars

# --- Access Control (v1 — defer full auth) ---
# CIDR ranges allowed for user + admin access
USER_ALLOW_CIDR=
ADMIN_ALLOW_CIDR=
# Trusted proxy for X-Forwarded-For (nginx container IP or LAN)
TRUSTED_PROXY_CIDR=127.0.0.1/32
# Trust header carrying claimed username
TRUST_USER_HEADER=X-Onemcp-User
# Default role assigned to new users
DEFAULT_ROLE=contributor
# Bootstrap role lists (comma-separated usernames)
MAINTAINER_USERNAMES=
ADMIN_USERNAMES=admin

# --- Emergency Kill Switch ---
# Set to true to reject all requests with 503 (except /health)
EMERGENCY_LOCKDOWN=false

# --- Public URLs ---
PUBLIC_API_URL=http://localhost/api

# --- GitLab (P2) ---
# Deploy tokens per skills repo, populated in P2
GITLAB_WEBHOOK_SECRET=change-me-webhook-hmac
GITLAB_BASE_URL=https://gitlab.internal

# --- Embedding (P4) ---
EMBEDDING_MODEL_PATH=/opt/models/multilingual-e5-small
EMBEDDING_DIM=384

# --- Observability (P6) ---
LOG_LEVEL=info
PROMETHEUS_ENABLED=true
