# =========================================
# OneMCP v1 — Environment Configuration
# Copy to .env and edit before docker compose up
# =========================================

# --- Postgres ---
POSTGRES_DB=onemcp
POSTGRES_USER=onemcp
POSTGRES_PASSWORD=change-me-use-hex-only-no-special-chars

# Postgres tuning (staging: 512MB/2GB/8MB/100; production: 4GB/12GB/32MB/200)
PG_SHARED_BUFFERS=512MB
PG_EFFECTIVE_CACHE=2GB
PG_WORK_MEM=8MB
PG_MAX_CONNECTIONS=100

# --- MinIO ---
MINIO_ROOT_USER=onemcp
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_BUCKET=onemcp-artifacts
ATTACHMENT_MAX_MB=100

# --- Access Control (v1 — defer full auth) ---
# CIDR ranges allowed for user + admin access
USER_ALLOW_CIDR=
ADMIN_ALLOW_CIDR=
# Trusted proxy for X-Forwarded-For (nginx container IP or LAN)
TRUSTED_PROXY_CIDR=127.0.0.1/32
# Trust header carrying claimed username
TRUST_USER_HEADER=X-Onemcp-User
# Default role assigned to new users
DEFAULT_ROLE=contributor
# Bootstrap role lists (comma-separated usernames)
MAINTAINER_USERNAMES=
ADMIN_USERNAMES=admin

# --- Emergency Kill Switch ---
# Set to true to reject all requests with 503 (except /health)
EMERGENCY_LOCKDOWN=false

# --- Public URLs ---
PUBLIC_API_URL=http://localhost/api

# --- GitLab (P2) ---
# GITLAB_BASE_URL rỗng = disable webhook processing + cron resync.
# Fill với https://gitlab.internal khi ready.
GITLAB_BASE_URL=
GITLAB_WEBHOOK_SECRET=change-me-webhook-hmac
# Deploy token (read_repository scope) — fetch skills mono-repo qua HTTPS.
GITLAB_MIRROR_TOKEN=
# Skills mono-repo layout: <namespace>/skills-<dept>. Path phần path_with_namespace.
SKILLS_MONO_REPO=onemcp/skills-kythuat
SKILLS_MONO_BRANCH=main
# Cron fallback resync (crontab format). Rỗng = disable.
SKILL_SYNC_CRON=*/15 * * * *
# Rate limit per IP cho approve action (req/min).
SKILL_APPROVE_RATE_LIMIT=20

# --- Embedding (P4) ---
EMBEDDING_MODEL_PATH=/opt/models/multilingual-e5-small
EMBEDDING_DIM=384

# --- Observability (P6) ---
LOG_LEVEL=info
PROMETHEUS_ENABLED=true

# --- Backup (P6) ---
# Cron format for backup service. Default 03:00 UTC daily.
BACKUP_CRON=0 3 * * *
BACKUP_RETAIN_DAYS=14
